{
    "manifest_version": 3,
    "name": "Screen Time Manager",
    "version": "0.2.0",
    "description": "Set per-site time limits and track daily visits + active time.",
    "icons": {
        "16": "extension_icon.png",
        "32": "extension_icon.png",
        "48": "extension_icon.png",
        "128": "extension_icon.png"
    },
    "action": {
        "default_title": "Screen Time Manager",
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": ["storage", "tabs", "alarms", "notifications"],
    "host_permissions": ["<all_urls>"]
}
